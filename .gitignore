# C/C++ 项目 .gitignore （只忽略编译产物，保留所有源码）
# 你的 .c .cpp .h .hpp Makefile 全部正常提交

# 编译生成的文件
*.o
*.obj
*.out
*.exe
*.so
*.so.*
*.a
*.lib
*.dll
*.dylib
*.ko

# 可执行程序（Linux/macOS 无后缀）
!*.c
!*.cpp
!*.h
!*.hpp
!*.hxx
!Makefile
!makefile
!*.mk
!*.md
!*.txt
!*.sh

# 编辑器临时文件
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/

# 构建目录
build/
bin/
obj/
debug/
release/

# 日志
*.log
